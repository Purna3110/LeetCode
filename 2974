class Solution:
    def numberGame(self, nums: List[int]) -> List[int]:
        nums.sort()
        arr=[]
        if len(nums)%2==0:
            for i in range(len(nums)-1):
                if i%2==0:
                    arr.append(max(nums[i],nums[i+1]))
                    arr.append(min(nums[i],nums[i+1]))
                else:
                    continue
            return arr
